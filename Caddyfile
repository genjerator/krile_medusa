# Caddy reverse proxy for the Strato VPS.
# Automatic HTTPS: Caddy issues + renews Let's Encrypt certs for every hostname
# below (ports 80/443 must be reachable and DNS must point at the VPS).
# Upstreams are the docker-compose service names on the internal network.
{
	# Email used for the Let's Encrypt account / expiry notices.
	email e.medjesi@gmail.com
}

# ─── Admin + Medusa backend ──────────────────────────────────────────────────
admin.alcoccodrillo.de {
	# Browsers without an "lng" cookie get a permanent German one, so the
	# admin language survives cleared site data / closed browsers.
	@noLng not header Cookie *lng=*
	header @noLng Set-Cookie "lng=de; Path=/; Max-Age=31536000; SameSite=Lax"
	reverse_proxy medusa:9000
}

# ─── Krile storefront (krile_medusa-storefront) ──────────────────────────────
industries.alcoccodrillo.de {
	reverse_proxy storefront-planeta-industries:8000
}

# ─── Planeta storefront (planetagmbh_medusa-storefront) ──────────────────────
planeta.alcoccodrillo.de {
	reverse_proxy storefront-planeta:8000
}

# ─── Uptime Kuma (uptime monitoring + status page) ───────────────────────────
status.alcoccodrillo.de {
	reverse_proxy uptime-kuma:3001
}
